Bootstrap: docker
From: ubuntu:24.04

%arguments
    # GPU architecture: gfx942 (MI300X), gfx90a (MI210), gfx906 (MI50), gfx1100 (RX 7900 XT)
    GPU_ARCH=gfx942
    # Git branch to build from
    BRANCH=main

%post
    # Create standard bind mount points for host data
    mkdir -p /data/rsf /data/results /data/testdata
    export DEBIAN_FRONTEND=noninteractive

    # Update package lists
    apt-get update

    # Install essential build tools and dependencies
    apt-get install -y \
        build-essential \
        cmake \
        git nano vim \
        wget curl \
        ca-certificates \
        pkg-config \
        python3 python3-pip \
        bc \
        numactl \
        hwloc

    # Install ROCm prerequisites and package
    wget https://repo.radeon.com/amdgpu-install/7.0.1/ubuntu/noble/amdgpu-install_7.0.1.70001-1_all.deb
    apt-get install -y ./amdgpu-install_7.0.1.70001-1_all.deb
    rm -f ./amdgpu-install_7.0.1.70001-1_all.deb
    apt-get update

    # Install ROCm full (HIP, libraries, tools)
    amdgpu-install --usecase=rocm,hip --no-dkms -y

    export ROCM_PATH=/opt/rocm
    export PATH=$ROCM_PATH/bin:$PATH

    # ====================================
    # Clone and build hip-compression-toolkit
    # ====================================
    GPU_ARCH="{{ GPU_ARCH }}"
    BRANCH="{{ BRANCH }}"

    cd /opt
    git clone --branch "$BRANCH" --single-branch --depth 1 \
        https://github.com/cristianokunas/hip-compression-toolkit.git
    cd hip-compression-toolkit
    mkdir -p build && cd build

    # Determine wave size flag for RDNA3
    WAVE32_FLAG=""
    if [ "$GPU_ARCH" = "gfx1100" ]; then
        WAVE32_FLAG="-DUSE_WARPSIZE_32=ON"
    fi

    echo "Building hip-compression-toolkit for $GPU_ARCH ..."
    CMAKE_PREFIX_PATH=/opt/rocm/lib/cmake cmake .. \
        -DCMAKE_HIP_ARCHITECTURES="$GPU_ARCH" \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_BENCHMARKS=ON \
        -DBUILD_TESTS=ON \
        -DCMAKE_INSTALL_PREFIX=/opt/hipcomp \
        $WAVE32_FLAG

    make -j$(nproc)
    make install

    # Verify benchmarks were built
    echo "=== Built benchmark executables ==="
    ls -la /opt/hip-compression-toolkit/build/benchmarks/benchmark_*_chunked 2>/dev/null || \
    ls -la /opt/hip-compression-toolkit/build/bin/benchmark_*_chunked 2>/dev/null || \
    echo "WARNING: No benchmark executables found"

    # Clean up build artifacts to reduce image size
    cd /opt/hip-compression-toolkit/build
    rm -rf CMakeFiles benchmarks/CMakeFiles src/CMakeFiles tests/CMakeFiles
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    export ROCM_PATH=/opt/rocm
    export PATH=/opt/hipcomp/bin:/opt/hip-compression-toolkit/build/bin:/opt/rocm/bin:/usr/local/bin:$PATH
    export LD_LIBRARY_PATH=/opt/hipcomp/lib:/opt/rocm/lib:/usr/local/lib:$LD_LIBRARY_PATH
    export HIPCOMP_ROOT=/opt/hip-compression-toolkit
    export HIPCOMP_BUILD=/opt/hip-compression-toolkit/build
    export HIPCOMP_SCRIPTS=/opt/hip-compression-toolkit/scripts

%runscript
    exec /opt/hip-compression-toolkit/scripts/singularity_entrypoint.sh "$@"

%help
    hipCOMP Benchmark Container
    ============================
    Pre-built with ROCm + hipcomp benchmarks (LZ4, Snappy, Cascaded).

    Quick usage:
      singularity run --rocm --bind /path/to/rsf/run:/data/rsf hipcomp.sif -r /data/rsf

    Or with custom output:
      singularity run --rocm \
        --bind /path/to/rsf/run:/data/rsf \
        --bind ./my_results:/data/results \
        hipcomp.sif -r /data/rsf -o /data/results

    See all options:
      singularity run hipcomp.sif --help

%labels
    Author cakunas
    Version 2.1
    Description Ubuntu 24.04 container with ROCm + hip-compression-toolkit benchmarks
